# dd-demo-toolkit configuration
# =============================
#
# This file holds **references** to secrets, not the secrets themselves.
# Plain-text Datadog API/APP keys in this file violate the corp secret-
# handling policy — see README § "Handling secrets" for the policy and
# migration steps from a plain-text .env.
#
# Workflow:
#   1. Install the 1Password CLI:        brew install --cask 1password-cli
#   2. Sign in once:                     eval "$(op signin)"
#   3. Put your DD keys in 1Password    (one item, two fields, in any vault you own)
#   4. Replace the op:// references below with the vault/item/field path you used
#   5. Run commands via the Makefile (`make up`, `make setup`, `make ui`, ...).
#      Each target wraps the underlying command in `op run --env-file=.env --`,
#      which resolves op:// references into short-lived process env vars.
#      The resolved values never touch disk and only exist for the lifetime
#      of the child process.

# ---- Secrets (stored in 1Password, NOT here) --------------------------------
#
# Format: op://<vault>/<item>/<field>
#
# These literal strings are NOT secrets. They are references. `op run`
# substitutes them at command invocation. Putting a plain-text key here
# is a policy violation; the web UI's save endpoint will reject it.
DD_API_KEY=op://Employee/Datadog/api-key
DD_APP_KEY=op://Employee/Datadog/app-key

# ---- Non-secret config ------------------------------------------------------

# Your Datadog site (datadoghq.com for US1, us3.datadoghq.com, datadoghq.eu, ...)
DD_SITE=datadoghq.com

# Vertical selection (healthcare, finance, manufacturing, insurance, hospitality)
DD_DEMO_VERTICAL=healthcare

# Optional: sub-vertical overlay. Layered additively on the base vertical.
# Currently shipped: `bd` on top of `healthcare`. Comment out for base only.
# DD_DEMO_SUB_VERTICAL=bd

# Simulator settings — seconds between metric/log emissions.
EMIT_INTERVAL=15

# Optional: custom display name shown in Datadog instead of the vertical name.
# DISPLAY_NAME=My Custom Demo
