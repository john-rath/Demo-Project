# Datadog Demo Toolkit Configuration
# ===================================
#
# This file contains all configuration needed to run the dd-demo-toolkit.
# Copy this file to `.env` and fill in your Datadog credentials.

# Required: Your Datadog credentials
# Get these from: https://app.datadoghq.com/organization/settings/api-keys
DD_API_KEY=your_api_key_here
DD_APP_KEY=your_app_key_here

# Your Datadog site (datadoghq.com for US, datadoghq.eu for EU, etc.)
DD_SITE=datadoghq.com

# Vertical selection (healthcare, finance, manufacturing, insurance, hospitality)
# This determines which demo scenario is simulated
DD_DEMO_VERTICAL=healthcare

# Optional: sub-vertical overlay name. Layered additively on the base
# vertical. Today: `bd` is shipped on top of `healthcare` (Pyxis
# MedStation cascade). Leave commented/blank to run base vertical only.
# DD_DEMO_SUB_VERTICAL=bd

# Simulator settings
# EMIT_INTERVAL: Time in seconds between metric/log emissions (default: 15)
EMIT_INTERVAL=15

# Optional: Custom display name override
# If set, this will be used as the application name in Datadog instead of the vertical name
# DISPLAY_NAME=My Custom Demo
