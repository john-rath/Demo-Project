        "font_size": "14",
        "text_align": "left",
        "vertical_align": "top",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {"x": 0, "y": 0, "width": 12, "height": 2}
    },

    {
      "definition": {
        "title": "Cabinets Online",
        "type": "query_value",
        "requests": [{"formulas": [{"formula": "query1"}], "queries": [{"data_source": "metrics", "name": "query1", "query": "sum:hospital.device.online{device_type:pyxis_medstation,$floor,$wing,$department}", "aggregator": "last"}], "response_format": "scalar"}],
        "autoscale": true,
        "precision": 0
      },
      "layout": {"x": 0, "y": 2, "width": 2, "height": 2}
    },
    {
      "definition": {
        "title": "Dispenses (5m)",
        "type": "query_value",
        "requests": [{"formulas": [{"formula": "query1"}], "queries": [{"data_source": "metrics", "name": "query1", "query": "sum:hospital.pyxis.dispense_events_total{device_type:pyxis_medstation,$floor,$wing,$department}.as_count()", "aggregator": "sum"}], "response_format": "scalar"}],
        "autoscale": true,
        "precision": 0
