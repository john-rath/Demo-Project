        "autoscale": true,
        "precision": 0
      },
      "layout": {
        "x": 10,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "type": "note",
        "content": "## Nurse Call Response",
        "background_color": "purple",
        "font_size": "16",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 12,
        "height": 1
      }
    },
    {
      "definition": {
        "title": "Avg Response Time (sec) by Floor",
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "avg:hospital.nursecall.response_time_sec{*} by {hospital.floor}"
              }
            ],
            "response_format": "timeseries",
            "display_type": "line"
          }
        ],
        "markers": [
          {
            "value": "y = 120",
            "display_type": "warning dashed",
            "label": "Target: 2 min"
          },
          {
            "value": "y = 180",
            "display_type": "error dashed",
            "label": "SLA Breach"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 5,
        "width": 6,
        "height": 3
      }
    },
