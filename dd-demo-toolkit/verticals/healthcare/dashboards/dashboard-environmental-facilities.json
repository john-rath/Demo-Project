                "query": "avg:hospital.env.hvac_setpoint_delta_f{$floor,$wing} by {hospital.floor}"
              }
            ],
            "response_format": "timeseries",
            "display_type": "line"
          }
        ],
        "markers": [
          {
            "value": "y = 2",
            "display_type": "warning dashed",
            "label": "+2\u00b0F"
          },
          {
            "value": "y = -2",
            "display_type": "warning dashed",
            "label": "-2\u00b0F"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 5,
        "width": 6,
        "height": 3
      }
    },
