{
  "title": "Environmental & Facilities \u2014 AdventHealth",
  "description": "Facilities & Compliance: HVAC compliance, air quality, power systems, regulatory monitoring.",
  "widgets": [
    {
      "id": 1,
      "definition": {
        "type": "note",
        "content": "# Environmental & Facilities Management\nHVAC compliance, OR air quality, power systems, and regulatory monitoring across the hospital.",
        "background_color": "vivid_orange",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 2
      }
    },
    {
      "id": 2,
      "definition": {
        "title": "Sensors Online",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:hospital.device.online{device.category:environmental}"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0
      },
      "layout": {
        "x": 0,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 3,
      "definition": {
        "title": "Avg Room Temp (\u00b0F)",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "avg:hospital.env.room_temperature_f{*}",
                "aggregator": "last"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 1
      },
      "layout": {
        "x": 3,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 4,
      "definition": {
        "title": "Avg AQI",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "avg:hospital.env.air_quality_aqi{*}",
                "aggregator": "last"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0
      },
      "layout": {
        "x": 6,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 5,
      "definition": {
        "title": "Water Leaks Detected",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:hospital.env.water_leak_detected{*}",
                "aggregator": "last"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0
      },
      "layout": {
        "x": 9,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 10,
      "definition": {
        "type": "note",
        "content": "## HVAC & Temperature Compliance",
        "background_color": "orange",
        "font_size": "16",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 12,
        "height": 1
      }
    },
    {
      "id": 11,
      "definition": {
        "title": "Room Temperature by Floor",
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "avg:hospital.env.room_temperature_f{$floor,$wing} by {hospital.floor}"
              }
            ],
            "response_format": "timeseries",
            "display_type": "line"
          }
        ],
        "markers": [
          {
            "value": "y = 68",
            "display_type": "ok dashed",
            "label": "Min Comfort"
          },
          {
            "value": "y = 75",
            "display_type": "ok dashed",
            "label": "Max Comfort"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 5,
        "width": 6,
        "height": 3
      }
    },
    {
      "id": 12,
      "definition": {
        "title": "HVAC Setpoint Deviation (\u00b0F) by Floor",
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
