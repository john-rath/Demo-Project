    {
      "definition": {
        "title": "Total Devices Online",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:hospital.device.online{$floor,$wing,$department,$device_type,$category,$manufacturer}",
                "aggregator": "last"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0,
        "custom_links": []
      },
      "layout": {
        "x": 0,
        "y": 2,
        "width": 3,
        "height": 2
