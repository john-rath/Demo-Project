{
  "title": "Network & Clinical Engineering — Healthcare Demo",
  "description": "IT & Biomed Leadership: Wireless coverage, switch health, device connectivity, signal quality across the hospital.",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# Network & Clinical Engineering\nWireless coverage, infrastructure health, and clinical device connectivity across all floors.",
        "background_color": "vivid_green",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "APs Online",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:hospital.device.online{device.type:wireless_ap,$floor,$wing}"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0
      },
      "layout": {
        "x": 0,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Switches Online",
