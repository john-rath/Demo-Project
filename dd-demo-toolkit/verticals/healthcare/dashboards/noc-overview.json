{
  "title": "🏥 Healthcare NOC — Network & Device Operations Center",
  "description": "SolarWinds-style NOC overview for hospital infrastructure monitoring. Real-time device status, alerts, network health, and facility operations across all floors and departments. Fully dynamic — all navigation and status panels auto-populate from live metric data.",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# 🏥 Healthcare NOC — Network & Device Operations Center\n\n**Real-time Infrastructure Monitoring** | Hospital-wide device status, alerts, and network health\n\nUse the template variables above to drill down by **Floor → Wing → Department → Device Type → Manufacturer** • All navigation is live-driven from metric tags",
        "background_color": "vivid_blue",
        "font_size": "13",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 1
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "🎯 Current Filter Context",
        "widgets": [
          {
            "definition": {
              "title": "Devices in Scope",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "count:hospital.device.online{$floor,$wing,$department,$device_type,$manufacturer}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "Locations Active",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "count:hospital.device.online{$device_type,$department} by {floor,wing}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "Alerts (Filtered)",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:hospital.device.alerts_total{$floor,$wing,$department,$device_type}.as_count()"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "Avg Signal (Filtered)",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:hospital.device.signal_strength_dbm{$floor,$wing,$department,$device_type}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 0
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 1,
        "width": 12,
        "height": 2
      }
