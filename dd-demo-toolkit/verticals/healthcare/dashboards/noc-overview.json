            "definition": {
              "title": "Device Types — Online Percentage",
              "type": "toplist",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "(avg:hospital.device.online{$floor,$wing,$department} by {device_type}) * 100"
                    }
                  ],
                  "queries": [],
                  "response_format": "scalar",
                  "sort": {
                    "count": 25,
                    "order_by": [
                      {
                        "type": "formula",
                        "index": 0,
                        "order": "desc"
                      }
                    ]
                  }
                }
              ],
              "style": {
                "display": {
                  "type": "numbers"
                }
              },
              "conditional_formats": [
                {
                  "comparator": ">",
                  "value": 90,
                  "color": "vivid_green"
