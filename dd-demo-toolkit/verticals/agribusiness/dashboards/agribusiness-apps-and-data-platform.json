{
  "title": "Bunge — Apps & Data Platform (cross-cutting) [dd-demo-toolkit:agribusiness]",
  "description": "The cross-cutting thesis: every revenue app depends on the one GCP data platform. A stale CME feed, SAP corruption, or a failed pipeline degrades Bunge Mobile, myBunge, BungeServices, FRM, and BungeAg at once. This view watches the platform and the apps together. [dd-demo-toolkit:agribusiness]",
  "layout_type": "ordered",
  "reflow_type": "fixed",
  "widgets": [
    {
      "definition": {"type": "note", "content": "# One data platform → every revenue app\n\nBunge Mobile, myBunge, BungeServices, FRM, and BungeAg all read the **same GCP data platform** (SAP + Salesforce + CME). A data issue here is a **simultaneous, silent** hit to every app — and nothing watches it today. Watch the platform (top) and the apps (bottom) on one screen.", "background_color": "vivid_orange", "font_size": "14", "text_align": "left", "show_tick": false},
      "layout": {"x": 0, "y": 0, "width": 12, "height": 2}
    },
    {
      "definition": {"type": "query_value", "title": "Records Processed / sec", "requests": [{"formulas": [{"formula": "q"}], "queries": [{"data_source": "metrics", "name": "q", "query": "avg:agri.dataplatform.records_processed_per_sec{environment:production}", "aggregator": "avg"}], "response_format": "scalar"}], "autoscale": true, "precision": 0},
      "layout": {"x": 0, "y": 2, "width": 4, "height": 2}
    },
    {
      "definition": {"type": "query_value", "title": "Pipeline Error Rate", "requests": [{"formulas": [{"formula": "q"}], "queries": [{"data_source": "metrics", "name": "q", "query": "avg:agri.dataplatform.pipeline_error_rate{environment:production}", "aggregator": "avg"}], "response_format": "scalar", "conditional_formats": [{"comparator": ">", "value": 0.015, "palette": "white_on_red"}, {"comparator": ">", "value": 0.008, "palette": "white_on_yellow"}, {"comparator": "<=", "value": 0.008, "palette": "white_on_green"}]}], "autoscale": true, "precision": 3},
      "layout": {"x": 4, "y": 2, "width": 4, "height": 2}
    },
    {
      "definition": {"type": "query_value", "title": "SAP Sync Lag (s)", "requests": [{"formulas": [{"formula": "q"}], "queries": [{"data_source": "metrics", "name": "q", "query": "max:agri.dataplatform.sap_sync_lag_sec{environment:production}", "aggregator": "max"}], "response_format": "scalar", "custom_unit": "s"}], "autoscale": true, "precision": 1},
      "layout": {"x": 8, "y": 2, "width": 4, "height": 2}
    },
    {
      "definition": {"type": "timeseries", "title": "Data Platform Freshness — CME Feed Age + SAP Sync Lag (s)", "show_legend": true, "requests": [{"formulas": [{"formula": "feed", "alias": "CME feed age"}, {"formula": "sap", "alias": "SAP sync lag"}], "queries": [{"data_source": "metrics", "name": "feed", "query": "avg:agri.dataplatform.pricing_feed_age_sec{environment:production}"}, {"data_source": "metrics", "name": "sap", "query": "avg:agri.dataplatform.sap_sync_lag_sec{environment:production}"}], "response_format": "timeseries", "display_type": "line"}], "markers": [{"value": "y = 20", "display_type": "error dashed", "label": "Stale"}]},
      "layout": {"x": 0, "y": 4, "width": 6, "height": 3}
    },
    {
      "definition": {"type": "timeseries", "title": "Data Platform Pipeline Error Rate by Region", "show_legend": true, "requests": [{"formulas": [{"formula": "q"}], "queries": [{"data_source": "metrics", "name": "q", "query": "avg:agri.dataplatform.pipeline_error_rate{environment:production} by {region}"}], "response_format": "timeseries", "display_type": "line"}]},
      "layout": {"x": 6, "y": 4, "width": 6, "height": 3}
    },
    {
      "definition": {"type": "timeseries", "title": "Revenue App Error Rate by Service", "show_legend": true, "requests": [{"formulas": [{"formula": "q"}], "queries": [{"data_source": "metrics", "name": "q", "query": "sum:agri.app.errors_total{environment:production,service_name:(frm-pricing-platform OR bunge-mobile-bff OR mybunge-portal OR bungeservices-portal OR bungeag-web)} by {service_name}"}], "response_format": "timeseries", "display_type": "bars"}]},
      "layout": {"x": 0, "y": 7, "width": 6, "height": 3}
    },
    {
      "definition": {"type": "timeseries", "title": "Revenue App Latency by Service (ms)", "show_legend": true, "requests": [{"formulas": [{"formula": "q"}], "queries": [{"data_source": "metrics", "name": "q", "query": "avg:agri.app.latency_ms{environment:production,service_name:(frm-pricing-platform OR bunge-mobile-bff OR mybunge-portal OR bungeservices-portal OR bungeag-web)} by {service_name}"}], "response_format": "timeseries", "display_type": "line"}]},
      "layout": {"x": 6, "y": 7, "width": 6, "height": 3}
    }
  ]
}
