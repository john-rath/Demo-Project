{
  "title": "RevPAR & Revenue Intelligence — Hospitality Demo",
  "description": "Revenue Intelligence dashboard tracking RevPAR performance, occupancy trends, and booking health across the hospitality portfolio. [dd-demo-toolkit:hospitality]",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# Revenue Intelligence\nRevPAR performance, occupancy trends, and booking health across the hospitality portfolio.",
        "background_color": "vivid_blue",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": { "x": 0, "y": 0, "width": 12, "height": 2 }
    },
    {
      "definition": {
        "title": "RevPAR",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.revpar{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0
      },
      "layout": { "x": 0, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Occupancy Rate",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.occupancy_rate_pct{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "%"
      },
      "layout": { "x": 3, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "ADR",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.adr{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "$"
      },
      "layout": { "x": 6, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Daily Revenue",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.revenue.total_daily{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "$"
      },
      "layout": { "x": 9, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "RevPAR by Brand",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.revpar{property_type:$property_type,region:$region} by {property_type}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 0, "y": 4, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Occupancy Rate by Region",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.occupancy_rate_pct{property_type:$property_type,region:$region} by {region}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 6, "y": 4, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Reservations Portal Booking Error Rate",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "errors / requests * 100" }],
          "queries": [{
            "data_source": "metrics",
            "name": "errors",
            "query": "sum:hospitality.app.errors_total{service_name:reservations-portal}"
          }, {
            "data_source": "metrics",
            "name": "requests",
            "query": "sum:hospitality.app.requests_total{service_name:reservations-portal}"
          }],
          "response_format": "timeseries",
          "display_type": "bars"
        }]
      },
      "layout": { "x": 0, "y": 7, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Revenue Engine Latency (max)",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "max:hospitality.app.latency_ms{service_name:revenue-management-engine}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 6, "y": 7, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "ADR vs RevPAR Trend",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }, { "formula": "query2" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.adr{property_type:$property_type,region:$region}"
          }, {
            "data_source": "metrics",
            "name": "query2",
            "query": "avg:hospitality.revpar{property_type:$property_type,region:$region}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 0, "y": 10, "width": 12, "height": 3 }
    }
  ],
  "template_variables": [
    { "name": "property_type", "prefix": "property_type", "default": "*" },
    { "name": "region", "prefix": "region", "default": "*" }
  ],
  "layout_type": "ordered"
}
