{
  "title": "AI Stay Planner & Revenue Intelligence — Hospitality Demo",
  "description": "AI-powered Stay Planner performance dashboard tracking inference latency, recommendation acceptance, token usage, and revenue attribution from the Reservations Portal AI features. [dd-demo-toolkit:hospitality]",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# AI Stay Planner & Revenue Intelligence\nAI model performance, recommendation quality, and revenue attribution from the Reservations Portal's AI-powered stay planner.",
        "background_color": "vivid_purple",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": { "x": 0, "y": 0, "width": 12, "height": 2 }
    },
    {
      "definition": {
        "title": "AI Inference Latency (avg)",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.ai.inference_latency_ms{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar",
          "conditional_formats": [
            { "comparator": "<=", "value": 200, "palette": "white_on_green" },
            { "comparator": "<=", "value": 500, "palette": "white_on_yellow" },
            { "comparator": ">", "value": 500, "palette": "white_on_red" }
          ]
        }],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "ms"
      },
      "layout": { "x": 0, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Recommendation Acceptance Rate",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.ai.recommendation_acceptance_rate{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar",
          "conditional_formats": [
            { "comparator": ">=", "value": 60, "palette": "white_on_green" },
            { "comparator": ">=", "value": 40, "palette": "white_on_yellow" },
            { "comparator": "<", "value": 40, "palette": "white_on_red" }
          ]
        }],
        "autoscale": true,
        "precision": 1,
        "custom_unit": "%"
      },
      "layout": { "x": 3, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "AI-Attributed Revenue",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.ai.revenue_attributed_usd{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "$"
      },
      "layout": { "x": 6, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "AI Requests / Interval",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.ai.requests_total{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0
      },
      "layout": { "x": 9, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "type": "note",
        "content": "## Model Performance",
        "background_color": "gray",
        "font_size": "12",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": { "x": 0, "y": 4, "width": 12, "height": 1 }
    },
    {
      "definition": {
        "title": "Inference Latency Over Time",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.ai.inference_latency_ms{property_type:$property_type,region:$region} by {region}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }],
        "markers": [
          {
            "display_type": "warning dashed",
            "value": "y = 200",
            "label": "Latency SLO (200ms)"
          },
          {
            "display_type": "error dashed",
            "value": "y = 500",
            "label": "Critical Threshold"
          }
        ]
      },
      "layout": { "x": 0, "y": 5, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Token Usage Trend",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.ai.token_usage_total{property_type:$property_type,region:$region} by {region}"
          }],
          "response_format": "timeseries",
          "display_type": "bars"
        }]
      },
      "layout": { "x": 6, "y": 5, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "type": "note",
        "content": "## Revenue Impact & Business Metrics",
        "background_color": "gray",
        "font_size": "12",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": { "x": 0, "y": 8, "width": 12, "height": 1 }
    },
    {
      "definition": {
        "title": "Recommendation Acceptance Rate by Brand",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.ai.recommendation_acceptance_rate{property_type:$property_type,region:$region} by {property_type}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }],
        "markers": [
          {
            "display_type": "ok dashed",
            "value": "y = 60",
            "label": "Target Acceptance (60%)"
          }
        ]
      },
      "layout": { "x": 0, "y": 9, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "AI-Attributed Revenue by Brand",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.ai.revenue_attributed_usd{property_type:$property_type,region:$region} by {property_type}"
          }],
          "response_format": "timeseries",
          "display_type": "bars"
        }]
      },
      "layout": { "x": 6, "y": 9, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Stay Planner API Performance (Reservations Portal)",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.app.latency_ms{service_name:reservations-portal}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 0, "y": 12, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "AI Request Volume vs Revenue Correlation",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }, { "formula": "query2" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.ai.requests_total{property_type:$property_type,region:$region}"
          }, {
            "data_source": "metrics",
            "name": "query2",
            "query": "sum:hospitality.ai.revenue_attributed_usd{property_type:$property_type,region:$region}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 6, "y": 12, "width": 6, "height": 3 }
    }
  ],
  "template_variables": [
    { "name": "property_type", "prefix": "property_type", "default": "*" },
    { "name": "region", "prefix": "region", "default": "*" }
  ],
  "layout_type": "ordered"
}
