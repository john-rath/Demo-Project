    {
      "definition": {
        "type": "note",
        "content": "# Meraki AP Deep Dive\nPer-property signal quality, client density analysis, and incident correlation with IoT and guest experience.",
        "background_color": "vivid_blue",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": { "x": 0, "y": 13, "width": 12, "height": 2 }
    },

    {
      "definition": {
        "title": "Meraki AP — Signal Strength by Property (dBm)",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.network.signal_strength_dbm{device_type:meraki_ap,property_type:$property_type,region:$region} by {property_type}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }],
        "markers": [
          { "value": "y = -50", "display_type": "warning dashed", "label": "Degraded (<-50 dBm)" },
          { "value": "y = -60", "display_type": "error dashed", "label": "Critical (<-60 dBm)" }
        ]
      },
      "layout": { "x": 0, "y": 15, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Meraki AP — Client Density per AP",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.network.connected_clients{device_type:meraki_ap,property_type:$property_type,region:$region} by {property_type}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }],
        "markers": [
          { "value": "y = 45", "display_type": "error dashed", "label": "Overload Threshold (>45)" },
          { "value": "y = 35", "display_type": "warning dashed", "label": "High Density (>35)" }
        ]
      },
      "layout": { "x": 6, "y": 15, "width": 6, "height": 3 }
    },

    {
