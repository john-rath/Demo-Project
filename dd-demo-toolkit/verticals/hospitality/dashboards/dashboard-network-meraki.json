{
  "title": "Network Engineering (Cisco/Meraki) — Hospitality Demo",
  "description": "Cisco Meraki wireless infrastructure: AP health, signal quality, client density, channel utilization, and incident correlation across all Hospitality properties. [dd-demo-toolkit:hospitality]",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# Network Infrastructure\nCisco Meraki wireless, switching, and guest connectivity across all properties.",
        "background_color": "vivid_green",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": { "x": 0, "y": 0, "width": 12, "height": 2 }
    },
    {
      "definition": {
        "title": "APs Online",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.device.online{device_type:meraki_ap,property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0
      },
      "layout": { "x": 0, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Switches Online",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.device.online{device_type:cisco_switch,property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0
      },
      "layout": { "x": 3, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Total Clients",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.network.connected_clients{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0
      },
      "layout": { "x": 6, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Avg Latency",
        "type": "query_value",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.network.latency_ms{property_type:$property_type,region:$region}"
          }],
          "response_format": "scalar"
        }],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "ms"
      },
      "layout": { "x": 9, "y": 2, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Channel Utilization by Property",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "avg:hospitality.network.channel_utilization_pct{property_type:$property_type,region:$region} by {property_type}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 0, "y": 4, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Connected Clients by Region",
        "type": "timeseries",
        "requests": [{
          "formulas": [{ "formula": "query1" }],
          "queries": [{
            "data_source": "metrics",
            "name": "query1",
            "query": "sum:hospitality.network.connected_clients{property_type:$property_type,region:$region} by {region}"
          }],
          "response_format": "timeseries",
          "display_type": "line"
        }]
      },
      "layout": { "x": 6, "y": 4, "width": 6, "height": 3 }
    },
