            "response_format": "timeseries",
            "display_type": "line",
            "on_right_yaxis": false
          },
          {
            "formulas": [{ "formula": "query2" }],
            "queries": [{
              "data_source": "metrics",
              "name": "query2",
              "query": "avg:hospitality.network.connected_clients{device_type:meraki_ap,property_type:extended_stay,region:apac}"
