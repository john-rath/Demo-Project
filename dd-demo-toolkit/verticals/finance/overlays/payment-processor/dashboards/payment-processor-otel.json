{
  "title": "Payment Processor — OTel Baseline",
  "description": "Chapter 2 dashboard proving Datadog as a first-class OTel destination for payment processor infrastructure. Six sections map to the 221-requirement Visualisation layer MUSTs.",
  "layout_type": "ordered",
  "template_variables": [
    {
      "name": "region",
      "prefix": "region",
      "available_values": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"],
      "default": "*"
    },
    {
      "name": "environment",
      "prefix": "environment",
      "available_values": ["production", "staging", "dr-site"],
      "default": "production"
    }
  ],
  "widgets": [
    {
      "definition": {
        "type": "group",
        "title": "OTel Ingestion Health",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "**OTel Ingestion Health** — Datadog as a first-class OTel destination. Span volume, refused spans, and SDK instrumentation coverage across payment processor services. VIS-PR-001 (MUST): pre-built dashboards deployable via code.\n\n**Reading the scalars:** \"Received\" and \"Forwarded\" will differ slightly — that's expected batching lag, not data loss. Only \"Refused\" indicates a real problem: green (0) means the pipeline is healthy; red (>0) means backpressure.",
              "background_color": "blue",
              "font_size": "14",
              "text_align": "left"
            },
            "layout": { "x": 0, "y": 0, "width": 12, "height": 1 }
          },
          {
            "definition": {
              "title": "Span Volume by Exporter",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "spans" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "spans",
                      "query": "sum:otelcol_exporter_sent_spans_total{*} by {exporter}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "area"
                }
              ]
            },
            "layout": { "x": 0, "y": 1, "width": 6, "height": 3 }
          },
          {
            "definition": {
              "title": "Metric Points Exported & Refused Spans",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    { "formula": "pts", "alias": "Metric points exported" },
                    { "formula": "refused", "alias": "Refused spans" }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "pts",
                      "query": "sum:otelcol_exporter_sent_metric_points_total{*}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "refused",
                      "query": "sum:otelcol_receiver_refused_spans_total{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            },
            "layout": { "x": 6, "y": 1, "width": 6, "height": 3 }
          },
          {
            "definition": {
              "title": "Received Spans (OTLP in)",
              "type": "query_value",
              "autoscale": true,
              "precision": 0,
              "requests": [
                {
                  "formulas": [{ "formula": "acc", "number_format": { "unit": { "type": "canonical_unit", "unit_name": "span" } } }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "acc",
                      "query": "sum:otelcol_receiver_accepted_spans_total{*}",
                      "aggregator": "sum"
                    }
                  ],
                  "response_format": "scalar"
                }
              ]
            },
            "layout": { "x": 0, "y": 4, "width": 4, "height": 2 }
          },
          {
            "definition": {
              "title": "Forwarded to Datadog",
              "type": "query_value",
              "autoscale": true,
              "precision": 0,
              "requests": [
                {
                  "formulas": [{ "formula": "sent", "number_format": { "unit": { "type": "canonical_unit", "unit_name": "span" } } }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "sent",
                      "query": "sum:otelcol_exporter_sent_spans_total{*}",
                      "aggregator": "sum"
                    }
                  ],
                  "response_format": "scalar"
                }
              ]
            },
            "layout": { "x": 4, "y": 4, "width": 4, "height": 2 }
          },
          {
            "definition": {
              "title": "Refused Spans — 0 is healthy",
              "type": "query_value",
              "autoscale": true,
              "precision": 0,
              "requests": [
                {
                  "formulas": [{ "formula": "ref", "number_format": { "unit": { "type": "canonical_unit", "unit_name": "span" } } }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "ref",
                      "query": "sum:otelcol_receiver_refused_spans_total{*}",
                      "aggregator": "sum"
                    }
                  ],
                  "response_format": "scalar",
                  "conditional_formats": [
                    { "comparator": "=", "value": 0, "palette": "white_on_green" },
                    { "comparator": ">", "value": 0, "palette": "white_on_red" }
                  ]
                }
              ]
            },
            "layout": { "x": 8, "y": 4, "width": 4, "height": 2 }
          }
        ]
      },
      "layout": { "x": 0, "y": 0, "width": 12, "height": 7 }
    },
    {
      "definition": {
        "type": "group",
        "title": "Fleet Automation — Collector Governance (VIS-MCP-001, VIS-MCP-002)",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "**Fleet Automation** — the OpAMP alternative. OpAMP provides no inventory UI, no collector health metrics, no flare/debug capability. Fleet Automation provides all three. VIS-MCP-001 (MUST): agent inventory with last-seen timestamps. VIS-MCP-002 (MUST): collector configuration health.",
              "background_color": "green",
              "font_size": "14",
              "text_align": "left"
            },
            "layout": { "x": 0, "y": 0, "width": 12, "height": 1 }
          },
          {
            "definition": {
              "title": "Collector CPU (seconds)",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "cpu" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "cpu",
                      "query": "sum:otelcol_process_cpu_seconds_total{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "yaxis": { "label": "CPU seconds", "scale": "linear" }
            },
            "layout": { "x": 0, "y": 1, "width": 4, "height": 3 }
          },
          {
            "definition": {
              "title": "Collector Memory RSS (bytes)",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "mem" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "mem",
                      "query": "avg:otelcol_process_memory_rss_bytes{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "yaxis": { "label": "Bytes", "scale": "linear" }
            },
            "layout": { "x": 4, "y": 1, "width": 4, "height": 3 }
          },
          {
            "definition": {
              "title": "Batch Flush Events (throughput indicator)",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "flushes" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "flushes",
                      "query": "sum:otelcol_processor_batch_batch_size_trigger_send_total{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "bars"
                }
              ]
            },
            "layout": { "x": 8, "y": 1, "width": 4, "height": 3 }
          }
        ]
      },
      "layout": { "x": 0, "y": 7, "width": 12, "height": 5 }
    },
    {
      "definition": {
        "type": "group",
        "title": "Single-Pane-of-Glass Story (VIS-AC-001)",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "**VIS-AC-001 (MUST):** Metric anomaly → correlated log → root trace in ≤3 clicks.\n\n**Live demo path:** (1) Auth decline rate spike → context menu → **View logs** → Log Explorer opens at the spike timestamp. (2) In Log Explorer, find `WARNING Authorization DECLINED` entries from `authorization-engine` — the `card.pan` field is masked (e.g. `4532-****-****-7892`) by the Datadog **Sensitive Data Scanner** Credit Card Number rule (INS-L-001). (3) Click the trace ID in any log → APM waterfall opens.\n\n**Prerequisite:** SDS Credit Card Number rule must be enabled in Datadog → Logs → Sensitive Data Scanner.",
              "background_color": "yellow",
              "font_size": "14",
              "text_align": "left"
            },
            "layout": { "x": 0, "y": 0, "width": 12, "height": 2 }
          },
          {
            "definition": {
              "title": "Authorization Decline Rate by Region — Click spike to correlate logs",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "declines" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "declines",
                      "query": "avg:finserv.authorization.decline_rate_pct{$region,$environment,device_type:authorization_switch} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "markers": [
                {
                  "value": "y = 5",
                  "display_type": "error dashed",
                  "label": "Alert threshold"
                }
              ],
              "yaxis": { "label": "Decline rate %", "scale": "linear" }
            },
            "layout": { "x": 0, "y": 2, "width": 8, "height": 3 }
          },
          {
            "definition": {
              "title": "Fraud Score Latency by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "lat" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "lat",
                      "query": "avg:finserv.authorization.fraud_score_latency_ms{$region,$environment,device_type:fraud_switch} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            },
            "layout": { "x": 8, "y": 2, "width": 4, "height": 3 }
          }
        ]
      },
      "layout": { "x": 0, "y": 12, "width": 12, "height": 6 }
    },
    {
      "definition": {
        "type": "group",
        "title": "Authorization & Fraud Pipeline (Chapter 2 cascade)",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Auth Decision Latency by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "latency" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "latency",
                      "query": "avg:finserv.authorization.decision_latency_ms{$region,$environment,device_type:authorization_switch} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "markers": [
                { "value": "y = 180", "display_type": "error dashed", "label": "Alert threshold" }
              ],
              "yaxis": { "label": "Latency (ms)", "scale": "linear" }
            },
            "layout": { "x": 0, "y": 0, "width": 6, "height": 3 }
          },
          {
            "definition": {
              "title": "Fraud Switch False Positive Rate by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "fp" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "fp",
                      "query": "avg:finserv.authorization.false_positive_rate_pct{$region,$environment,device_type:fraud_switch} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "markers": [
                { "value": "y = 6", "display_type": "error dashed", "label": "Alert threshold" }
              ],
              "yaxis": { "label": "False positive rate %", "scale": "linear" }
            },
            "layout": { "x": 6, "y": 0, "width": 6, "height": 3 }
          },
          {
            "definition": {
              "title": "Authorization Approval Rate by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "approval" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "approval",
                      "query": "avg:finserv.authorization.approval_rate_pct{$region,$environment,device_type:authorization_switch} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "yaxis": { "label": "Approval rate %", "scale": "linear", "min": "95" }
            },
            "layout": { "x": 0, "y": 3, "width": 4, "height": 3 }
          },
          {
            "definition": {
              "title": "Tokenization Vault Utilization by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "util" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "util",
                      "query": "avg:finserv.tokenization.vault_utilization_pct{$region,$environment,device_type:tokenization_vault} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "yaxis": { "label": "Utilization %", "scale": "linear" }
            },
            "layout": { "x": 4, "y": 3, "width": 4, "height": 3 }
          },
          {
            "definition": {
              "title": "Tokenization Request Latency by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "lat" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "lat",
                      "query": "avg:finserv.tokenization.request_latency_ms{$region,$environment,device_type:tokenization_vault} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "yaxis": { "label": "Latency (ms)", "scale": "linear" }
            },
            "layout": { "x": 8, "y": 3, "width": 4, "height": 3 }
          }
        ]
      },
      "layout": { "x": 0, "y": 18, "width": 12, "height": 7 }
    },
    {
      "definition": {
        "type": "group",
        "title": "SLO & Error Budget (VIS-PR-003)",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "**VIS-PR-003 (MUST):** SLO tracking with compliance %, error budget, burn rate 1h/6h/24h, and month-end projection. Three SLOs covering the full payment processing chain.",
              "background_color": "purple",
              "font_size": "14",
              "text_align": "left"
            },
            "layout": { "x": 0, "y": 0, "width": 12, "height": 1 }
          },
          {
            "definition": {
              "title": "Clearing Queue Depth by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "queue" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "queue",
                      "query": "avg:finserv.clearing.queue_depth{$region,$environment,device_type:clearing_node} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "markers": [
                { "value": "y = 15000", "display_type": "error dashed", "label": "Critical threshold" }
              ],
              "yaxis": { "label": "Queue depth", "scale": "linear" }
            },
            "layout": { "x": 0, "y": 1, "width": 6, "height": 3 }
          },
          {
            "definition": {
              "title": "Settlement Gateway Failures by Region",
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [{ "formula": "failures" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "failures",
                      "query": "avg:finserv.clearing.settlement_failures_total{$region,$environment,device_type:settlement_gateway} by {region}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ],
              "yaxis": { "label": "Failures/tick", "scale": "linear" }
            },
            "layout": { "x": 6, "y": 1, "width": 6, "height": 3 }
          }
        ]
      },
      "layout": { "x": 0, "y": 25, "width": 12, "height": 5 }
    },
    {
      "definition": {
        "type": "group",
        "title": "Executive KPIs — Business Outcomes (VIS-PR-010)",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "**VIS-PR-010 (COULD):** Executive-level business KPIs without infrastructure detail. Network-wide auth success rate, tokenization throughput, and settlement SLA compliance — for the program audience who care about business outcomes, not device metrics.",
              "background_color": "white",
              "font_size": "14",
              "text_align": "left"
            },
            "layout": { "x": 0, "y": 0, "width": 12, "height": 1 }
          },
          {
            "definition": {
              "title": "Payment Authorization Approval Rate",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [{ "formula": "approval" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "approval",
                      "query": "avg:finserv.authorization.approval_rate_pct{device_type:authorization_switch}",
                      "aggregator": "avg"
                    }
                  ],
                  "response_format": "scalar"
                }
              ]
            },
            "layout": { "x": 0, "y": 1, "width": 4, "height": 2 }
          },
          {
            "definition": {
              "title": "Tokenization Throughput (TPS)",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [{ "formula": "tps" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "tps",
                      "query": "avg:finserv.tokenization.throughput_tps{device_type:tokenization_vault}",
                      "aggregator": "avg"
                    }
                  ],
                  "response_format": "scalar"
                }
              ]
            },
            "layout": { "x": 4, "y": 1, "width": 4, "height": 2 }
          },
          {
            "definition": {
              "title": "Settlement Latency (ms)",
              "type": "query_value",
              "requests": [
                {
                  "formulas": [{ "formula": "lat" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "lat",
                      "query": "avg:finserv.clearing.settlement_latency_ms{device_type:settlement_gateway}",
                      "aggregator": "avg"
                    }
                  ],
                  "response_format": "scalar"
                }
              ]
            },
            "layout": { "x": 8, "y": 1, "width": 4, "height": 2 }
          }
        ]
      },
      "layout": { "x": 0, "y": 30, "width": 12, "height": 4 }
    }
  ]
}
