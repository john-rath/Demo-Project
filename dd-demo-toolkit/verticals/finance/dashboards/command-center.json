{
  "title": "Global Financial Services Platform \u2014 Command Center",
  "description": "Real-time observability across trading, payments, fraud detection, and risk infrastructure. Mission-critical financial services operations dashboard.",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# Global Financial Services Command Center\n### Real-time Operations & SLA Monitoring\n\nTrading Platform \u00b7 Payment Systems \u00b7 Fraud Detection \u00b7 Risk Management \u00b7 Compliance\n\nObserving **65+ infrastructure nodes** across **4 regions** \u00b7 **3 environments** \u00b7 **4 business units**",
        "background_color": "vivid_blue",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Transaction Throughput (24h)",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:finserv.payment_gateway.transactions_per_sec{$region,$environment}",
                "aggregator": "avg"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0,
        "custom_links": []
      },
      "layout": {
        "x": 0,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Payment Success Rate",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1 * 100"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "(sum:finserv.app.requests_total{service_name:payment-processing-engine} - sum:finserv.app.errors_total{service_name:payment-processing-engine}) / sum:finserv.app.requests_total{service_name:payment-processing-engine}",
                "aggregator": "avg"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 2,
        "custom_links": []
      },
      "layout": {
        "x": 2,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Fraud Detection Alerts",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:finserv.fraud_detection_node.alerts_generated{$region}",
                "aggregator": "sum"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0,
        "custom_links": []
      },
      "layout": {
        "x": 4,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Trading Order Fill Rate",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1 * 100"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:finserv.matching_engine.order_throughput_per_sec{$region,$environment} / (sum:finserv.matching_engine.order_throughput_per_sec{$region,$environment} + sum:finserv.matching_engine.rejected_orders_total{$region,$environment})",
                "aggregator": "avg"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 2,
        "custom_links": []
      },
      "layout": {
        "x": 6,
        "y": 2,
        "width": 2,
        "height": 2
