{
  "title": "Global Financial Services Platform — Command Center",
  "description": "Real-time observability across trading, payments, fraud detection, and risk infrastructure. Mission-critical financial services operations dashboard.",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# Global Financial Services Command Center\n### Real-time Operations & SLA Monitoring\n\nTrading Platform · Payment Systems · Fraud Detection · Risk Management · Compliance\n\nObserving **65+ infrastructure nodes** across **4 regions** · **3 environments** · **4 business units**",
        "background_color": "vivid_blue",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Transaction Throughput (24h)",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:finserv.payment_gateway.transactions_per_sec{$region,$environment}",
                "aggregator": "avg"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0,
        "custom_links": []
      },
      "layout": {
        "x": 0,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Payment Success Rate",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "(requests - errors) / requests * 100"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "requests",
                "query": "sum:finserv.app.requests_total{service_name:payment-processing-engine}",
                "aggregator": "avg"
              },
              {
                "data_source": "metrics",
                "name": "errors",
                "query": "sum:finserv.app.errors_total{service_name:payment-processing-engine}",
                "aggregator": "avg"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 2,
        "custom_links": []
      },
      "layout": {
        "x": 2,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Fraud Detection Alerts",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:finserv.fraud_detection_node.alerts_generated{$region}",
                "aggregator": "sum"
              }
            ],
            "response_format": "scalar"
