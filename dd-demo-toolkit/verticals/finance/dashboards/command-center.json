        "autoscale": true,
        "precision": 0,
        "custom_links": []
      },
      "layout": {
        "x": 4,
        "y": 2,
        "width": 2,
        "height": 2
      }
    },
    {
      "definition": {
        "title": "Trading Order Fill Rate",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "throughput / (throughput + rejected) * 100"
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "throughput",
                "query": "sum:finserv.matching_engine.order_throughput_per_sec{$region,$environment}",
                "aggregator": "avg"
              },
              {
                "data_source": "metrics",
                "name": "rejected",
                "query": "sum:finserv.matching_engine.rejected_orders_total{$region,$environment}",
                "aggregator": "avg"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 2,
        "custom_links": []
      },
      "layout": {
        "x": 6,
        "y": 2,
        "width": 2,
        "height": 2
