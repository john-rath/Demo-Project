{
  "title": "Insurance Operations Command Center",
  "description": "Multi-region claims, underwriting, and payments operations dashboard",
  "layout_type": "ordered",
  "is_read_only": false,
  "tags": [],
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "Claims Intake Volume",
                "data_source": "metrics",
                "query": "sum:insurer.claims.received_total{service:claims-intake} by {region}"
              }
            ],
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "title": "Claims Received (per min by region)",
        "yaxis": {
          "label": "Claims/min",
          "scale": "linear"
        }
      }
    },
    {
      "definition": {
        "type": "gauge",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "FNOL SLA Compliance",
                "data_source": "metrics",
                "query": "100 * (count:insurer.claims.fnol_to_assignment_sec{service:claims-management-platform} where fnol_to_assignment_sec <= 14400 / count:insurer.claims.fnol_to_assignment_sec{service:claims-management-platform})"
              }
            ]
          }
        ],
        "title": "Claims Processing SLA (FNOL-to-Assignment <4h)",
        "gauge": {
          "type": "gauge",
          "min": 0,
          "max": 100
        },
        "thresholds": {
          "critical": 90,
          "warning": 95
        }
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "Processing Latency P95",
                "data_source": "metrics",
                "query": "p95:insurer.claims.processing_ms{device_type:claims_intake_server} by {region}"
              }
            ],
            "style": {
              "palette": "warm",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "title": "Claims Processing Latency (P95 by region)",
        "yaxis": {
          "label": "ms",
          "scale": "linear"
        },
        "markers": [
          {
            "value": 1200,
            "label": "SLA Threshold"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "Document Queue Depth",
                "data_source": "metrics",
                "query": "max:insurer.claims.document_queue_depth{device_type:document_processor} by {region}"
              }
            ],
            "style": {
              "palette": "warm",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "title": "Document Processor Queue Depth (by region)",
        "yaxis": {
          "label": "Documents",
          "scale": "linear"
        }
      }
    },
    {
      "definition": {
        "type": "gauge",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "OCR Accuracy",
                "data_source": "metrics",
                "query": "avg:insurer.claims.ocr_confidence_pct{device_type:document_processor}"
              }
            ]
          }
        ],
        "title": "Document OCR Accuracy (%)",
        "gauge": {
          "type": "gauge",
          "min": 80,
          "max": 100
        },
        "thresholds": {
          "critical": 92,
          "warning": 94
        }
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "Quote Volume",
                "data_source": "metrics",
                "query": "sum:insurer.quoting.requests_total{service:digital-quoting-engine} by {region}"
              }
            ],
            "style": {
              "palette": "cool",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "title": "Digital Quoting Volume (per min by region)",
        "yaxis": {
          "label": "Quotes/min",
          "scale": "linear"
        }
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "Quoting Latency P99",
                "data_source": "metrics",
                "query": "p99:insurer.quoting.response_ms{service:digital-quoting-engine} by {region}"
              }
            ],
            "style": {
              "palette": "warm",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "title": "Quoting Engine Latency (P99 by region)",
        "yaxis": {
          "label": "ms",
          "scale": "linear"
        },
        "markers": [
          {
            "value": 3500,
            "label": "Alert Threshold"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "gauge",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "Quoting Availability",
                "data_source": "metrics",
                "query": "100 * (sum:insurer.quoting.requests_total{service:digital-quoting-engine} - sum:insurer.quoting.errors_total{service:digital-quoting-engine}) / sum:insurer.quoting.requests_total{service:digital-quoting-engine}"
              }
            ]
          }
        ],
        "title": "Digital Quoting Availability (SLA: 99.95%)",
        "gauge": {
          "type": "gauge",
          "min": 99,
          "max": 100
        },
        "thresholds": {
          "critical": 99.9,
          "warning": 99.95
        }
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "Payment Volume",
                "data_source": "metrics",
